{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "UASOPS CSV Row Schema",
  "description": "Esquema de validación para filas de archivos CSV del sistema UASOPS",
  "type": "object",

  "required": ["Id", "Type", "Date", "Reported By"],

  "properties": {
    "Id": {
      "type": "string",
      "description": "Identificador único del registro (ej: #54363286)",
      "pattern": "^#?[0-9]+$"
    },
    "Type": {
      "type": "string",
      "description": "Tipo de formulario. Debe contener uno de los identificadores reconocidos.",
      "examples": [
        "Bitacora De Vuelo Diario",
        "Informe De Mision Cumplida",
        "Planeamiento De La Mision",
        "Analisis Y Evaluacion Del Riesgo",
        "Mantenimiento Preventivo"
      ]
    },
    "Date": {
      "type": "string",
      "description": "Fecha y hora del registro",
      "examples": ["2026-06-02 10:01am", "2026-06-01 09:24pm"]
    },
    "Reported By": {
      "type": "string",
      "description": "Nombre completo del piloto o técnico que reporta",
      "examples": ["FRANCISCO JAVIER PERDIGON GARCIA"]
    },
    "Account": {
      "type": "string",
      "description": "Nombre del cliente / cuenta (opcional)",
      "examples": ["UAS - CASA DE CAMPO LA CALERA"]
    },
    "Post": {
      "type": "string",
      "description": "Puesto o zona de operación (opcional)",
      "examples": ["Vigilante recorredor zona 1"]
    },
    "Latitude": {
      "type": "string",
      "description": "Latitud GPS de la operación (opcional, para futuras versiones)",
      "pattern": "^-?[0-9]+\\.?[0-9]*$"
    },
    "Longitude": {
      "type": "string",
      "description": "Longitud GPS de la operación (opcional, para futuras versiones)",
      "pattern": "^-?[0-9]+\\.?[0-9]*$"
    }
  },

  "additionalProperties": true,

  "examples": [
    {
      "Id": "#54363286",
      "Type": "Bitacora De Vuelo Diario.Bitacora De Vuelo Diario",
      "Date": "2026-06-02 10:01am",
      "Reported By": "FRANCISCO JAVIER PERDIGON GARCIA",
      "Account": "UAS - CASA DE CAMPO LA CALERA",
      "Post": "Vigilante recorredor zona 1"
    }
  ]
}
